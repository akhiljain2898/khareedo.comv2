# ── Razorpay ──────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# ── Upstash Redis ─────────────────────────────────────────────────────────────
UPSTASH_REDIS_URL=rediss://default:xxxx@xxxx.upstash.io:6379
UPSTASH_REDIS_TOKEN=xxxx

# ── PostgreSQL (Railway) ──────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@host:5432/railway

# ── Cloudflare R2 ─────────────────────────────────────────────────────────────
R2_ACCOUNT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxx
R2_ACCESS_KEY_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxx
R2_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxx
R2_BUCKET_NAME=khareedo

# ── APIs ──────────────────────────────────────────────────────────────────────
SERPER_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxx
FIRECRAWL_API_KEY=fc-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Google Sheets (service account JSON as single-line string) ────────────────
# Paste the entire service account JSON here as one line (escape quotes)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
GOOGLE_SHEET_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── App ───────────────────────────────────────────────────────────────────────
APP_BASE_URL=https://khareedo.com
